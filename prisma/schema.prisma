generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Product {
  id             Int             @id @default(autoincrement())
  codigo         String          @unique
  nombre         String
  precio         Decimal         @db.Decimal(10, 2)
  imagenUrl      String
  galeria        String[]        @default([])
  descripcion1   String
  descripcion2   String
  categoryId     Int?
  category       Category?       @relation(fields: [categoryId], references: [id])
  stock          Int             @default(0)
  minStock       Int             @default(0)
  incomingOrders IncomingOrder[]
  quotationItems QuotationItem[]
  createdAt      DateTime?       @default(now()) @db.Timestamp(6)
  updatedAt      DateTime?       @default(now()) @db.Timestamp(6)
}

model IncomingOrder {
  id            Int       @id @default(autoincrement())
  productId     Int
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  cantidad      Int       @default(0)
  fechaPedido   DateTime  @default(now()) @db.Timestamp(6)
  fechaEstimada DateTime? @db.Timestamp(6)
  estado        String    @default("EN_CAMINO") // EN_CAMINO, COMPLETADO, CANCELADO
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  updatedAt     DateTime? @default(now()) @db.Timestamp(6)
}


/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Category {
  id           Int       @id @default(autoincrement())
  nombre       String    @unique
  mostrarEnWeb Boolean   @default(true)
  products     Product[]
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  password           String
  isSuperAdmin       Boolean?  @default(false)
  createdAt          DateTime? @default(now()) @db.Timestamp(6)
  updatedAt          DateTime? @default(now()) @db.Timestamp(6)
  resetToken         String?
  resetTokenExpiry   DateTime? @db.Timestamp(6)
}

model Client {
  id              Int                @id @default(autoincrement())
  nit             String?            @unique
  nombre          String
  email           String?
  telefono        String?
  contacto        String?
  direccion       String?
  ciudad          String?
  departamento    String?
  pais            String?            @default("Colombia")
  quotations      Quotation[]
  createdAt       DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?          @default(now()) @db.Timestamp(6)
}

enum QuotationStatus {
  COTIZACION
  APROBADA
  RECHAZADA
  CUENTA_COBRO
  PAGADA
}

model Quotation {
  id                Int             @id @default(autoincrement())
  numeroCotizacion  String          @unique
  numeroCuentaCobro String?         @unique // Generado al facturar / pasar a CUENTA_COBRO
  estado            QuotationStatus @default(COTIZACION)
  total             Decimal         @db.Decimal(10, 2) @default(0)
  clientId          Int
  client            Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items             QuotationItem[]
  fechaCotizacion   DateTime        @default(now()) @db.Timestamp(6)
  fechaCuentaCobro  DateTime?       @db.Timestamp(6)
  fechaVencimiento  DateTime?       @db.Timestamp(6)
  createdAt         DateTime?       @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?       @default(now()) @db.Timestamp(6)
}

model QuotationItem {
  id             Int       @id @default(autoincrement())
  quotationId    Int
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId      Int
  product        Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  cantidad       Int       @default(1)
  precioUnitario Decimal   @db.Decimal(10, 2)
  createdAt      DateTime? @default(now()) @db.Timestamp(6)
  updatedAt      DateTime? @default(now()) @db.Timestamp(6)
}

model SystemSettings {
  id                   Int     @id @default(1)
  startQuotationNumber Int     @default(1)
  startBillNumber      Int     @default(1)
  bankDetails          String  @default("Transferencias a:\nNequi: 316 831 4501\nBancolombia Ahorros: 123-456789-01")
  companyName          String  @default("CONSUMIBLES & REPUESTOS")
  companySlogan        String  @default("Equipos de Corte Plasma y Soldadura Industrial")
  companyPhone         String  @default("+57 316 831 4501")
}

